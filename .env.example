# ============================================================
# Frigate Apple Silicon — Environment Configuration
# Copy this file to .env and fill in your values.
# DO NOT commit .env to version control.
# ============================================================

# ============================================================
# REQUIRED VARIABLES
# These values MUST be provided for the setup to succeed.
# ============================================================

# Directory on THIS machine where Frigate config.yaml and models are stored.
LOCAL_CONFIG_DIR=/opt/frigate/config

# Database directory — keep this on a local SSD for performance. 
# Never place SQLite databases on a network drive.
LOCAL_DB_DIR=/opt/frigate/db

# The image tag to deploy. Use 'stable-standard-arm64' or a pinned version.
# See https://github.com/blakeblackshear/frigate/releases
FRIGATE_VERSION_TAG=stable-standard-arm64


# ============================================================
# OPTIONAL VARIABLES 
# You can leave these as-is or comment them out if not used.
# ============================================================

# --- Storage Backend Selection ---
# The deployment script will automatically copy the correct template
# to docker-compose.yaml based on whether NFS_IP is set.

# [OPTIONAL] Media directory — used only for local storage (when NFS_IP is NOT set)
# If NFS_IP is blank, Frigate will store media to this local path.
LOCAL_MEDIA_DIR=/opt/frigate/media

# [OPTIONAL] The IP address or hostname of your NFS server.
# Set this to mount an external NAS for media storage instead of local SSD.
NFS_IP=192.168.1.100

# [OPTIONAL] The NFS export path on the server.
NFS_SHARE_PATH=/volume1/frigate_media

# --- Frigate RTSP Credentials ---
# [OPTIONAL] Used by Frigate internally if configured in your config.yaml
FRIGATE_RTSP_USER=viewer
FRIGATE_RTSP_PASSWORD=changeme

# --- Power Scheduler ---
# [OPTIONAL] Dictates when the machine should automatically wake up or power on.
# Format: MTWRFSU HH:MM:SS
WAKE_SCHEDULE=MTWRFSU 06:00:00
